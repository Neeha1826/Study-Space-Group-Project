# Copy to .env or set these in your system / IDE (same host as Flask).

# School ThingsBoard: replace with your group URL, username, and password.
# THINGSBOARD_URL=https://example-thingsboard.cardiff.ac.uk
# THINGSBOARD_USERNAME=your_tenant@thingsboard.org
# THINGSBOARD_PASSWORD=your_password

# If requests fails SSL verification (self-signed cert), set to 0.
# THINGSBOARD_VERIFY_SSL=0
